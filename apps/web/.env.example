# Board source selection
# ----------------------
# If BOARD_REPO is set, the UI reads a live board from GitHub. Otherwise it renders the bundled
# sample-board/ fixture.

# owner/name of the repo whose .claude/tasks board to render.
# BOARD_REPO=owner/name
# Branch/ref to read. Defaults to the repo's default branch.
# BOARD_REF=main

# Auth (optional for public repos). Preferred: a GitHub App (fine-grained, read-only contents).
# Provide ALL THREE to use the App. The private key may contain literal \n (they're restored).
# GITHUB_APP_ID=123456
# GITHUB_APP_INSTALLATION_ID=12345678
# GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----

# Fallback: a fine-grained personal access token with read-only contents on the target repo.
# GITHUB_TOKEN=github_pat_xxx

# Fixture override (only used when BOARD_REPO is unset): path to a repo root containing .claude/tasks.
# BOARD_FS_ROOT=../../sample-board
